# Woodcreek Agents — Environment Configuration
# Copy to .env and fill in values for your environment.

# ── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=woodcreek_agents

# ── Kafka (Confluent Cloud / Lattice) ───────────────────────────────────────
KAFKA_BROKERS=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_TOPIC_EVENTS=woodcreek.events.v1

# ── Slack ───────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DELIVERY_CHANNEL=         # Channel ID for reminder delivery notifications

# ── Telnyx SMS ──────────────────────────────────────────────────────────────
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=
TELNYX_MESSAGING_PROFILE_ID=

# ── Email (SMTP via WorkMail) ───────────────────────────────────────────────
SMTP_HOST=smtp.mail.us-east-1.awsapps.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=reminders@woodcreek.me

# ── WorkMail EWS Calendar ──────────────────────────────────────────────────
WORKMAIL_EWS_EMAIL=
WORKMAIL_EWS_PASSWORD=
WORKMAIL_EWS_REGION=us-east-1

# ── LLM Provider ───────────────────────────────────────────────────────────
LLM_PROVIDER=groq              # groq | openai | anthropic | local
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Observability ───────────────────────────────────────────────────────────
LANGSMITH_API_KEY=
HONEYHIVE_API_KEY=
